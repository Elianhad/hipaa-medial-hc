# =============================================
# HIPAA HCE — Backend Environment Variables
# Copy to .env.local and fill in real values
# =============================================

# Server
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=app_user
DB_PASSWORD=CHANGE_ME
DB_NAME=hipaa_hce
DB_SSL=false

# Auth0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.hipaa-hce.com
AUTH0_CLIENT_ID=CHANGE_ME
AUTH0_CLIENT_SECRET=CHANGE_ME
AUTH0_MANAGEMENT_AUDIENCE=https://your-tenant.auth0.com/api/v2/

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_S3_BUCKET_CLINICAL=hipaa-hce-clinical-files
AWS_HEALTHLAKE_DATASTORE_ID=CHANGE_ME
AWS_HEALTHLAKE_ENDPOINT=https://healthlake.us-east-1.amazonaws.com/datastore/CHANGE_ME/r4
